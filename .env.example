# Copy this file to .env for local development.
# Do not commit the real .env file; it may contain private database credentials.

DATABASE_URL="postgresql://postgres:password@localhost:5432/first_dawn_dev?schema=public"

# Required in production for internal Mission Control access.
MISSION_CONTROL_KEY="replace-with-a-long-private-access-key"

# Development bypass is enabled by default. Set this to true to test the login flow locally.
MISSION_CONTROL_REQUIRE_LOGIN=false

# Maximum Prisma interactive transaction time for one simulation tick.
ATLAS_SIMULATION_TRANSACTION_TIMEOUT_MS=180000
