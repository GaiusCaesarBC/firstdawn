{
  "name": "first-dawn",
  "version": "0.1.0",
  "private": true,
  "description": "First Dawn: a long-term artificial civilization simulation and observer platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scheduler": "vitest run tests/scheduler",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "world:seed": "prisma db seed",
    "world:verify": "node scripts/verify-worlds.js",
    "world:verify-actions": "node scripts/verify-world-actions.js",
    "profile:snapshots": "node ./node_modules/jiti/lib/jiti-cli.mjs scripts/profile-snapshots.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
